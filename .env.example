# Path where the manual Reddit login session is saved.
REDDIT_AUTH_STATE=.auth/reddit.json

# Set false if you want to watch the worker browser while debugging.
CRAWLER_HEADLESS=true

# Milliseconds between each scroll action.
CRAWLER_SCROLL_DELAY_MS=1200

# How many scrolls to perform per target page.
CRAWLER_SCROLL_STEPS=8

# Delay between crawler tasks. Keep this polite; do not hammer Reddit.
CRAWLER_TASK_DELAY_MS=5000

# Delay between full cycles when running continuously.
CRAWLER_CYCLE_DELAY_MS=300000

# Optional API handoff. Leave blank to run in local dry-run mode.
CRAWLER_API_URL=
CRAWLER_API_TOKEN=
CRAWLER_API_IMPORT_PATH=/api/crawler/import
CRAWLER_API_TARGETS_PATH=/api/crawler/targets

# Optional browser settings.
CRAWLER_USER_AGENT=
CRAWLER_PROXY_SERVER=
CRAWLER_PROXY_USERNAME=
CRAWLER_PROXY_PASSWORD=

# Optional debug HTML snapshots.
CRAWLER_SNAPSHOT_DIR=snapshots

# Optional JSON overrides. Example: ["daresgonewild","ChangingInPublic"]
CRAWLER_PRIORITY_SUBREDDITS=
CRAWLER_EXTRA_SUBREDDITS=
CRAWLER_EXTRA_USERS=
