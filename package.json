{
  "name": "openai-crawler",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.13.1",
  "scripts": {
    "login": "tsx src/login.ts",
    "crawl": "tsx src/index.ts",
    "crawl:once": "tsx src/index.ts --once",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write ."
  },
  "dependencies": {
    "dotenv": "latest",
    "playwright": "latest",
    "tsx": "latest",
    "zod": "latest"
  },
  "devDependencies": {
    "@types/node": "latest",
    "prettier": "latest",
    "typescript": "latest"
  }
}
